<section class="auth-screen">
  <div class="auth-shell auth-shell-wide">
    <div class="auth-brand-mark">
      <span class="site-logo">BL</span>
    </div>
    <p class="auth-kicker">Booking Lapangan</p>
    <h1 class="auth-title">Daftar Akun Baru</h1>
    <p class="auth-subtitle">Lengkapi data berikut untuk mulai booking lapangan dengan tampilan yang rapi dan konsisten.</p>

    <form action="/register" method="POST" class="mt-8 grid gap-4 md:grid-cols-2">
      <div class="md:col-span-2">
        <label class="auth-label">Nama Lengkap</label>
        <div class="auth-input-wrap">
          <i class="fa-regular fa-user"></i>
          <input type="text" name="name" value="<%= formData.name || '' %>" class="input auth-input" placeholder="Masukkan nama lengkap" />
        </div>
      </div>
      <div>
        <label class="auth-label">Email</label>
        <div class="auth-input-wrap">
          <i class="fa-regular fa-envelope"></i>
          <input type="email" name="email" value="<%= formData.email || '' %>" class="input auth-input" placeholder="nama@domain.com" />
        </div>
      </div>
      <div>
        <label class="auth-label">Telepon</label>
        <div class="auth-input-wrap">
          <i class="fa-solid fa-phone"></i>
          <input type="text" name="phone" value="<%= formData.phone || '' %>" class="input auth-input" placeholder="08xxxxxxxxxx" />
        </div>
      </div>
      <div>
        <label class="auth-label">Password</label>
        <div class="auth-input-wrap">
          <i class="fa-solid fa-lock"></i>
          <input type="password" name="password" class="input auth-input" placeholder="Buat password" />
        </div>
      </div>
      <div>
        <label class="auth-label">Konfirmasi Password</label>
        <div class="auth-input-wrap">
          <i class="fa-solid fa-shield-halved"></i>
          <input type="password" name="password_confirmation" class="input auth-input" placeholder="Ulangi password" />
        </div>
      </div>
      <button class="auth-submit md:col-span-2" type="submit">
        <i class="fa-solid fa-user-plus"></i>
        <span>Daftar</span>
      </button>
    </form>

    <p class="auth-switch">Sudah punya akun? <a href="/login">Masuk di sini</a></p>
  </div>
</section>
