<section class="auth-screen">
  <div class="auth-shell auth-shell-compact">
    <div class="auth-brand-mark">
      <span class="site-logo">BL</span>
    </div>
    <p class="auth-kicker">Booking Lapangan</p>
    <h1 class="auth-title">Selamat Datang</h1>
    <p class="auth-subtitle">Masuk untuk lanjut booking, cek jadwal, dan kelola akunmu </p>

    <form action="/login" method="POST" class="mt-8 space-y-4">
      <div>
        <label class="auth-label">Email</label>
        <div class="auth-input-wrap">
          <i class="fa-regular fa-envelope"></i>
          <input type="email" name="email" value="<%= formData.email || '' %>" class="input auth-input" placeholder="nama@domain.com" />
        </div>
      </div>
      <div>
        <label class="auth-label">Password</label>
        <div class="auth-input-wrap">
          <i class="fa-solid fa-lock"></i>
          <input type="password" name="password" class="input auth-input" placeholder="Masukkan password" />
        </div>
      </div>
      <button class="auth-submit" type="submit">
        <i class="fa-solid fa-arrow-right-to-bracket"></i>
        <span>Masuk</span>
      </button>
    </form>

    <p class="auth-switch">Belum punya akun? <a href="/register">Daftar akun baru</a></p>
  </div>
</section>
