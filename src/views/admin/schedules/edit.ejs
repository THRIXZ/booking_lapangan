<section class="rounded-[2rem] bg-white p-6 shadow-card">
  <h2 class="text-2xl font-black">Edit Jadwal</h2>
  <form action="/admin/schedules/<%= schedule.id %>?_method=PUT" method="POST" class="mt-6 grid gap-5 md:grid-cols-2">
    <div class="md:col-span-2">
      <label class="mb-2 block text-sm font-semibold">Lapangan</label>
      <select name="court_id" class="w-full rounded-2xl border border-slate-200 px-4 py-3">
        <% courts.forEach((court) => { %>
          <option value="<%= court.id %>" <%= Number(schedule.court_id) === court.id ? "selected" : "" %>><%= court.name %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Tanggal</label>
      <input type="date" name="date" value="<%= schedule.date.toISOString().slice(0, 10) %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3" />
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Ketersediaan</label>
      <select name="is_available" class="w-full rounded-2xl border border-slate-200 px-4 py-3">
        <option value="1" <%= Number(schedule.is_available) === 1 ? "selected" : "" %>>Tersedia</option>
        <option value="0" <%= Number(schedule.is_available) === 0 ? "selected" : "" %>>Tidak tersedia</option>
      </select>
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Jam Mulai</label>
      <input type="time" name="start_time" value="<%= String(schedule.start_time).slice(0, 5) %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3" />
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Jam Selesai</label>
      <input type="time" name="end_time" value="<%= String(schedule.end_time).slice(0, 5) %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3" />
    </div>
    <button class="md:col-span-2 rounded-2xl bg-slate-900 px-5 py-3 font-semibold text-white">Update Jadwal</button>
  </form>
</section>
