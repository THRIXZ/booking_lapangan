<section class="rounded-[2rem] bg-white p-6 shadow-card">
  <h2 class="text-2xl font-black">Tambah Jadwal</h2>
  <form action="/admin/schedules" method="POST" class="mt-6 grid gap-5 md:grid-cols-2">
    <div class="md:col-span-2">
      <label class="mb-2 block text-sm font-semibold">Lapangan</label>
      <select name="court_id" class="w-full rounded-2xl border border-slate-200 px-4 py-3">
        <% courts.forEach((court) => { %>
          <option value="<%= court.id %>" <%= Number(formData.court_id) === court.id ? "selected" : "" %>><%= court.name %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Tanggal</label>
      <input type="date" name="date" value="<%= formData.date || '' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3" />
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Ketersediaan</label>
      <select name="is_available" class="w-full rounded-2xl border border-slate-200 px-4 py-3">
        <option value="1">Tersedia</option>
        <option value="0">Tidak tersedia</option>
      </select>
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Jam Mulai</label>
      <input type="time" name="start_time" value="<%= formData.start_time || '' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3" />
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Jam Selesai</label>
      <input type="time" name="end_time" value="<%= formData.end_time || '' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3" />
    </div>
    <button class="md:col-span-2 rounded-2xl bg-slate-900 px-5 py-3 font-semibold text-white">Simpan Jadwal</button>
  </form>
</section>
