<section class="rounded-[2rem] bg-white p-6 shadow-card">
  <h2 class="text-2xl font-black">Tambah Lapangan</h2>
  <form action="/admin/courts" method="POST" enctype="multipart/form-data" class="mt-6 grid gap-5 md:grid-cols-2">
    <div>
      <label class="mb-2 block text-sm font-semibold">Nama Lapangan</label>
      <input type="text" name="name" value="<%= formData.name || '' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3" />
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Jenis</label>
      <select name="type" class="w-full rounded-2xl border border-slate-200 px-4 py-3">
        <% ["badminton", "futsal", "basket", "padel", "bola"].forEach((type) => { %>
          <option value="<%= type %>" <%= formData.type === type ? "selected" : "" %>><%= type %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Harga Per Jam</label>
      <input type="number" name="price_per_hour" value="<%= formData.price_per_hour || '' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3" />
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Status</label>
      <select name="status" class="w-full rounded-2xl border border-slate-200 px-4 py-3">
        <option value="active">active</option>
        <option value="inactive">inactive</option>
      </select>
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Upload Gambar</label>
      <input type="file" name="image_file" accept="image/*" class="w-full rounded-2xl border border-slate-200 px-4 py-2" />
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Atau URL Gambar</label>
      <input type="text" name="image" value="<%= formData.image || '' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3" />
    </div>
    <button class="md:col-span-2 rounded-2xl bg-slate-900 px-5 py-3 font-semibold text-white">Simpan</button>
  </form>
</section>
