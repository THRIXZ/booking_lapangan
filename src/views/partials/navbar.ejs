<nav class="site-nav">
  <div class="flex items-center gap-3">
    <div class="site-logo">BL</div>
    <div>
      <p class="text-xs uppercase tracking-[0.3em] text-slate-500">Booking Lapangan</p>
      <p class="text-sm font-semibold text-slate-900">Platform pemesanan lapangan</p>
    </div>
  </div>

  <% if (currentUser) { %>
    <details class="apple-menu">
      <summary class="apple-menu-btn" aria-label="Buka menu navigasi">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div class="apple-menu-panel">
        <p class="apple-menu-name"><%= currentUser.name %></p>
        <p class="apple-menu-role"><%= currentUser.role === "admin" ? "Admin" : "User" %></p>

        <% if (currentUser.role === "admin") { %>
          <a href="/admin/dashboard">Dashboard</a>
          <a href="/admin/courts">Courts</a>
          <a href="/admin/schedules">Schedules</a>
          <a href="/admin/bookings">Bookings</a>
        <% } else { %>
          <a href="/user/dashboard">Dashboard</a>
          <a href="/user/courts">Courts</a>
          <a href="/user/bookings">My Bookings</a>
        <% } %>

        <a href="/profile">Profile</a>
        <form action="/logout" method="POST">
          <button type="submit">Logout</button>
        </form>
      </div>
    </details>
  <% } else { %>
    <div class="flex items-center gap-2">
      <a class="btn-ghost" href="/login">Login</a>
      <a class="btn-primary" href="/register">Register</a>
    </div>
  <% } %>
</nav>
