<section class="rounded-[2rem] bg-white p-10 shadow-card">
  <h1 class="text-3xl font-black">500</h1>
  <p class="mt-3 text-slate-600">Terjadi error pada server.</p>
  <% if (error && error.message) { %>
    <pre class="mt-6 overflow-auto rounded-2xl bg-slate-950 p-4 text-xs text-slate-100"><%= error.message %></pre>
  <% } %>
</section>
