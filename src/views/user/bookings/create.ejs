<section class="mx-auto max-w-4xl rounded-[2rem] bg-white p-6 shadow-card">
  <div class="mb-6">
    <h2 class="text-2xl font-black">Buat Booking</h2>
    <p class="text-sm text-slate-600">Pilih lapangan, tanggal, dan jam bermainmu.</p>
  </div>

  <form action="/user/bookings" method="POST" class="grid gap-5 md:grid-cols-2">
    <div class="md:col-span-2">
      <label class="mb-2 block text-sm font-semibold">Lapangan</label>
      <select name="court_id" class="w-full rounded-2xl border border-slate-200 px-4 py-3">
        <% courts.forEach((court) => { %>
          <% const selectedId = formData.court_id || (selectedCourt ? String(selectedCourt.id) : ""); %>
          <option value="<%= court.id %>" <%= String(court.id) === String(selectedId) ? "selected" : "" %>>
            <%= court.name %> - Rp <%= Number(court.price_per_hour).toLocaleString("id-ID") %>/jam
          </option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Tanggal Booking</label>
      <input type="date" name="booking_date" value="<%= formData.booking_date || '' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3" />
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Catatan</label>
      <input type="text" name="notes" value="<%= formData.notes || '' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3" />
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Jam Mulai</label>
      <input type="time" name="start_time" value="<%= formData.start_time || '' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3" />
    </div>
    <div>
      <label class="mb-2 block text-sm font-semibold">Jam Selesai</label>
      <input type="time" name="end_time" value="<%= formData.end_time || '' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3" />
    </div>
    <button class="md:col-span-2 rounded-2xl bg-slate-900 px-5 py-3 font-semibold text-white">Simpan Booking</button>
  </form>
</section>
